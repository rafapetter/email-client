# Auth
NEXTAUTH_SECRET=your-secret-here-generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3004

# Encryption key for email credentials (32 bytes hex)
ENCRYPTION_KEY=generate-with-node-e-crypto-randomBytes-32-toString-hex

# Turso Database (optional — defaults to local SQLite file:./data/email-client.db)
# TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
# TURSO_AUTH_TOKEN=your-turso-auth-token
